{
  "name": "@kitlangton/behold",
  "version": "0.1.1",
  "description": "A local-first Markdown workspace for presenting agent work and collecting browser feedback.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitlangton/behold.git"
  },
  "homepage": "https://github.com/kitlangton/behold#readme",
  "bugs": "https://github.com/kitlangton/behold/issues",
  "files": [
    "dist",
    "server",
    "shared",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "behold": "server/behold-cli.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "cloudflare": {
    "bindings": {
      "BEHOLD_PUBLISH_TOKEN": {
        "description": "Generate a random token with `openssl rand -hex 32`; Behold uses it to authorize publishing from your local runtime."
      },
      "SNAPSHOTS": {
        "description": "R2 bucket containing your published Behold snapshots."
      }
    }
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "bun run typecheck && bun run build:client",
    "build:client": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "behold": "bun run server/behold-cli.ts",
    "mcp": "bun run server/behold-cli.ts mcp",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p cloudflare/tsconfig.json",
    "test": "vitest run",
    "cloudflare:dev": "wrangler dev",
    "cloudflare:deploy": "wrangler deploy",
    "deploy": "wrangler deploy",
    "export:published": "bun run scripts/export-published-doc.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:check": "bun run build && bun run test && npm pack --dry-run",
    "release": "bun run release:check && changeset publish",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.92",
    "@effect/platform-node-shared": "4.0.0-beta.92",
    "add-mcp": "^1.13.0",
    "diff": "^9.0.0",
    "effect": "4.0.0-beta.92",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@kobalte/core": "^0.13.12",
    "@shikijs/core": "4.3.1",
    "@shikijs/engine-javascript": "4.3.1",
    "@shikijs/langs": "4.3.1",
    "@shikijs/themes": "4.3.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "beautiful-mermaid": "^1.1.3",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "shiki": "^4.3.1",
    "solid-js": "^1.9.14",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.92"
  }
}
